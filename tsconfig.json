{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "composite": true,
    "declaration": true,
    "paths": {
      "@smart-stadiums/*": ["./*/src"]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "coverage"
  ]
}
