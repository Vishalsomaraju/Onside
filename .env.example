# Smart Stadiums & Tournament Operations
# Environment Variables

# ==========================================
# BACKEND CONFIGURATION (Render / Local)
# ==========================================
NODE_ENV=production
PORT=10000
AI_API_KEY=your_ai_key
# Explicit CORS Allowlist - Must match your Vercel frontend URL
FRONTEND_ORIGIN=https://smartstadiums.vercel.app

# Optional Neon Database config (if used for runtime or migrations)
DATABASE_URL=postgresql://...
DATABASE_URL_UNPOOLED=postgresql://...

# ==========================================
# FRONTEND CONFIGURATION (Vercel)
# ==========================================
# Point to your Render backend API
VITE_API_BASE_URL=https://smartstadiums-api.onrender.com
